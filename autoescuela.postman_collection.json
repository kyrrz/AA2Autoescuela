          "name": "/alumnos (V2)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"v2 tiene estructura de paginación correcta\", () => {\r",
                  "    const response = pm.response.json();\r",
                  "    \r",
                  "    pm.expect(response).to.have.property('content');\r",
                  "    pm.expect(response).to.have.property('pageable');\r",
                  "    pm.expect(response).to.have.property('totalElements');\r",
                  "\r",
                  "    pm.expect(response.content).to.be.an('array');\r",
                  "});\r",
                  "\r",
                  "pm.test(\"El filtrado por apellido funciona\", () => {\r",
                  "    const response = pm.response.json();\r",
                  "    const apellidoBuscado = pm.collectionVariables.get(\"apellidosAlumno\");\r",
                  "    \r",
                  "\r",
                  "    response.content.forEach((alumno) => {\r",
                  "        pm.expect(alumno.apellidos).to.include(apellidoBuscado);\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Metadatos de paginación coherentes\", () => {\r",
                  "    const response = pm.response.json();\r",
                  "    pm.expect(response.numberOfElements).to.equal(response.content.length);\r",
                  "    pm.expect(response.size).to.be.a('number');\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }

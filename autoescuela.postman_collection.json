        {
          "name": "/alumnos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", () => {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Estructura correcta\", () => {\r",
                  "    const response = pm.response.json();\r",
                  "    \r",
                  "    pm.collectionVariables.set(\"alumnoId\", response.id);\r",
                  "\r",
                  "    pm.expect(response).to.have.property('id');\r",
                  "    pm.expect(response).to.have.property('nombre');\r",
                  "    pm.expect(response).to.have.property('apellidos');\r",
                  "    pm.expect(response).to.have.property('email');\r",
                  "    pm.expect(response).to.have.property('telefono');\r",
                  "    pm.expect(response).to.have.property('direccion');\r",
                  "    pm.expect(response).to.have.property('ciudad');\r",
                  "    pm.expect(response).to.have.property('dni');\r",
                  "    pm.expect(response).to.have.property('fechaNacimiento');\r",
                  "    pm.expect(response).to.have.property('usaGafas');\r",
                  "    pm.expect(response).to.have.property('notaTeorico');\r",
                  "    pm.expect(response).to.have.property('autoescuela');\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Creado correctamente\", () => {\r",
                  "    const response = pm.response.json();\r",
                  "    pm.expect(response.nombre).to.eql('Alvaro')\r",
                  "    pm.expect(response.apellidos).to.eql('Reyes de Diego');\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
